{
  "cleanUrls": true,
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/database/**"
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/health",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/|health).*)",
      "destination": "/index.html"
    }
  ]
}
